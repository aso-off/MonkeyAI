# Git
.git
.git/
.gitignore
.gitattributes

# CI/CD (не нужно в образах)
.github/

# Mini-App (деплоится через GitHub Pages, не Docker)
mini-app/

# Infrastructure configs (монтируются как volume, не копируются в образ)
configs/

# Monitoring / deployment configs
deployment/

# Secrets (CRITICAL: никогда не должны попасть в build context)
.env
.env.*
secrets.env
!.env.example
!secrets.env.example

# Docker files
docker-compose.yml
docker-compose*.yml
*.override.yml

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
env/
ENV/
.venv/

# Logs and persistent data (mounted as volumes)
logs/
data/
bot/logs/
bot/data/
api/logs/

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Docs
README.md
*.md
LICENSE

