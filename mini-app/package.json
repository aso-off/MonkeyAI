{
  "name": "monkey-ai-mini-app",
  "version": "2.9.83",
  "private": true,
  "type": "module",
  "homepage": "https://telegram-mini-apps.github.io/vuejs-template",
  "scripts": {
    "deploy": "gh-pages -d dist",
    "dev": "vite",
    "dev:https": "cross-env HTTPS=true vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix"
  },
  "dependencies": {
    "@tma.js/sdk-vue": "^1.0.21",
    "dompurify": "^3.4.11",
    "eruda": "^3.4.3",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "katex": "^0.17.0",
    "lottie-web": "^5.13.0",
    "marked": "^18.0.5",
    "marked-katex-extension": "^5.1.10",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-mkcert": "^2.1.0",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
